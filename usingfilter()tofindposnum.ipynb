   "source": [
    "# Program to filter positive numbers\n",
    "\n",
    "numbers = [-10, 20, -30, 40, 50, -60]\n",
    "\n",
    "positive_numbers = list(filter(lambda x: x > 0, numbers))\n",
    "\n",
    "print(\"Original List:\", numbers)\n",
    "print(\"Positive Numbers:\", positive_numbers)"
   ]
  }

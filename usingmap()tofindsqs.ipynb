    "# program to find squares using map ()\n",
    "numbers = [1, 2, 3, 4, 5]\n",
    "squares = list(map(lambda x: x * x, numbers))\n",
    "print(\"Original List:\", numbers)\n",
    "print(\"Squares List:\", squares)"
   ]

    "# palindromme using lambda \n",
    "palindrome = lambda s: s == s[::-1]\n",
    "text = input(\"Enter a string: \")\n",
    "if palindrome(text):\n",
    "    print(\"Palindrome\")\n",
    "else:\n",
    "    print(\"Not a Palindrome\")"

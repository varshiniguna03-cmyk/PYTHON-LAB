   "source": [
    "# Program to sort tuples using lambda\n",
    "\n",
    "students = [\n",
    "    (\"Anu\", 85),\n",
    "    (\"Rahul\", 72),\n",
    "    (\"Priya\", 90),\n",
    "    (\"Kiran\", 78)\n",
    "]\n",
    "\n",
    "sorted_students = sorted(students, key=lambda x: x[1])\n",
    "\n",
    "print(\"Students Sorted by Marks:\")\n",
    "for student in sorted_students:\n",
    "    print(student)"
   ]
  }
 ],

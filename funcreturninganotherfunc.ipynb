    "# Program demonstrating higher-order function\n",
    "\n",
    "def multiplier(n):\n",
    "    return lambda x: x * n\n",
    "\n",
    "double = multiplier(2)\n",
    "triple = multiplier(3)\n",
    "\n",
    "print(\"Double of 5:\", double(5))\n",
    "print(\"Triple of 5:\", triple(5))"

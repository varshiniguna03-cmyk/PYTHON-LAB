   "source": [
    "# Program to calculate length of strings using map()\n",
    "\n",
    "words = [\"Python\", \"Java\", \"C\", \"JavaScript\"]\n",
    "\n",
    "lengths = list(map(lambda x: len(x), words))\n",
    "\n",
    "print(\"Words:\", words)\n",
    "print(\"Lengths:\", lengths)"
   ]
  }

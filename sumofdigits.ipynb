    "# sum of digits\n",
    "a=int(input(\"enter number\"))\n",
    "sum=0\n",
    "while a>0:\n",
    "    r=a%10\n",
    "    sum=sum+r\n",
    "    a = a //10\n",
    "    print(\"sum of digits=\",sum)"

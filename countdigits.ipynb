   "source": [
    "# Program to count digits\n",
    "num = int(input(\"Enter a number: \"))\n",
    "count = 0\n",
    "num = abs(num)   # handle negative numbers\n",
    "while num > 0:\n",
    "    num = num // 10\n",
    "    count += 1\n",
    "print(\"Number of digits:\", count)"
   ]
  }

   "source": [
    "# Program to find sum of first n natural numbers\n",
    "n = int(input(\"Enter a number: \"))\n",
    "sum = 0\n",
    "i = 1\n",
    "while i <= n:\n",
    "    sum += i\n",
    "    i += 1\n",
    "print(\"Sum of first\", n, \"natural numbers is\", sum)"
   ]
  }

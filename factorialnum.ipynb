   "source": [
    "# Program to find factorial\n",
    "num = int(input(\"Enter a number: \"))\n",
    "fact = 1\n",
    "for i in range(1, num + 1):\n",
    "    fact = fact * i\n",
    "print(\"Factorial of\", num, \"is\", fact)"
   ]
  }

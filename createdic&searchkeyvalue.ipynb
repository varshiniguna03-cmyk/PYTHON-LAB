    "# Create a dictionary and search for a key value\n",
    "student = {\n",
    "    \"name\": \"Varshini\",\n",
    "    \"age\": 17,\n",
    "    \"course\": \"ISE\"\n",
    "}\n",
    "key = \"age\"\n",
    "if key in student:\n",
    "    print(\"Value:\", student[key])\n",
    "else:\n",
    "    print(\"Key not found\")"
   ]
  }

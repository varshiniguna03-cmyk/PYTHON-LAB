    "#  Program to find sum using reduce() \n",
    "from functools import reduce\n",
    "numbers = [1, 2, 3, 4, 5]\n",
    "sum_result = reduce (lambda x, y: x + y, numbers)\n",
    "print(\"List Elements:\", numbers)\n",
    "print(\"Sum of Elements:\", sum_result)"
